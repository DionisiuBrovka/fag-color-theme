{
  "name": "fag-theme",
  "displayName": "FAG-theme",
  "description": "My cool theme",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.115.0"
  },
  "categories": [
    "Themes"
  ],
  "contributes": {
    "themes": [
      {
        "label": "FAG-default dark color theme",
        "uiTheme": "vs-dark",
        "path": "./themes/fag-default-dark-color-theme.json"
      },
      {
        "label": "FAG-default light color theme",
        "uiTheme": "vs",
        "path": "./themes/fag-default-light-color-theme.json"
      },
      {
        "label": "FAG-green dark color theme",
        "uiTheme": "vs-dark",
        "path": "./themes/fag-green-dark-color-theme.json"
      },
      {
        "label": "FAG-green light color theme",
        "uiTheme": "vs",
        "path": "./themes/fag-green-light-color-theme.json"
      }
    ]
  },
  "scripts": {
    "build:color-themes": "cd src && python build.py"
  }
}