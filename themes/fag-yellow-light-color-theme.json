{
  "$schema": "vscode://schemas/color-theme",
  "name": "fag-$yellow-color-theme",
  "type": "light",
  "colors": {
    "editor.background": "#000000",
    "editor.foreground": "#FFFFFF",
    "activityBarBadge.background": "#f6d32d",
    "sideBarTitle.foreground": "#FFFFFF"
  },
  "tokenColors": [
    {
      "name": "Comment",
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "fontStyle": "italic",
        "foreground": "#f6d32d"
      }
    }
  ]
}