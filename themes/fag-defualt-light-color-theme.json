{
  "$schema": "vscode://schemas/color-theme",
  "name": "fag-defualt-color-theme",
  "type": "light",
  "colors": {
    "focusBorder": "#00000000",
    "foreground": "#5e5c64",
    "disabledForeground": "#9a9996",
    "widget.border": "#00000000",
    "widget.shadow": "#00000000",
    "selection.background": "#3584e455",
    "descriptionForeground": "#c0bfbc",
    "errorForeground": "#ed333b",
    "icon.foreground": "#3d3846",
    "sash.hoverBorder": "#00000000",
    "window.activeBorder": "#3584e4",
    "window.inactiveBorder": "#00000000",
    "textBlockQuote.background": "#00000000",
    "textBlockQuote.border": "#00000000",
    "textCodeBlock.background": "#0f0f0f",
    "textLink.activeForeground": "#8fbaf2",
    "textLink.foreground": "#3584e4ee",
    "textPreformat.foreground": "#241f31",
    "textPreformat.background": "#1a5fb4",
    "textPreformat.border": "#00000000",
    "textSeparator.foreground": "#3d3846",
    "button.background": "#1a5fb4",
    "button.foreground": "#241f31",
    "button.border": "#00000000",
    "checkbox.background": "#f6f5f4",
    "checkbox.selectBackground": "#f6f5f4",
    "radio.activeBackground": "#f6f5f4",
    "radio.inactiveBackground": "#f6f5f4",
    "dropdown.background": "#f6f5f4",
    "dropdown.listBackground": "#deddda",
    "input.background": "#f6f5f4",
    "input.border": "#deddda",
    "scrollbar.background": "#00000000",
    "scrollbar.shadow": "#00000000",
    "scrollbarSlider.activeBackground": "#c0bfbc",
    "scrollbarSlider.background": "#deddda",
    "scrollbarSlider.hoverBackground": "#c0bfbc",
    "badge.foreground": "#241f31",
    "badge.background": "#245da3",
    "progressBar.background": "#3584e4",
    "list.activeSelectionBackground": "#00000026",
    "list.dropBackground": "#3584e422",
    "list.focusOutline": "#00000000",
    "activityBar.background": "#eeeded",
    "activityBarBadge.background": "#1a5fb4",
    "sideBar.background": "#eeeded",
    "sideBarSectionHeader.background": "#eeeded",
    "sideBarTitle.foreground": "#241f31",
    "sideBarTitle.border": "#deddda",
    "editorGroupHeader.tabsBackground": "#deddda",
    "tab.activeBackground": "#deddda",
    "tab.border": "#00000000",
    "tab.inactiveBackground": "#deddda",
    "editor.background": "#deddda",
    "editor.selectionBackground": "#3584e455",
    "panel.background": "#0f0f0f",
    "panelTitle.activeBorder": "#3584e4",
    "statusBar.background": "#f6f5f4",
    "statusBar.debuggingBackground": "#f6f5f4",
    "statusBar.noFolderBackground": "#f6f5f4",
    "statusBarItem.activeBackground": "#f6f5f4",
    "titleBar.activeBackground": "#f6f5f4",
    "menu.foreground": "#3d3846",
    "menu.background": "#f6f5f4",
    "commandCenter.background": "#eeeded",
    "commandCenter.border": "#00000000",
    "commandCenter.activeBorder": "#00000000",
    "commandCenter.inactiveBorder": "#00000000",
    "quickInput.background": "#f6f5f4"
