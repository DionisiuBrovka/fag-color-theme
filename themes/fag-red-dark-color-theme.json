{
  "$schema": "vscode://schemas/color-theme",
  "name": "fag-red-color-theme",
  "type": "dark",
  "colors": {
    "focusBorder": "#00000000",
    "foreground": "#c0bfbc",
    "disabledForeground": "#9a9996",
    "widget.border": "#00000000",
    "widget.shadow": "#00000000",
    "selection.background": "#e01b2455",
    "descriptionForeground": "#5e5c64",
    "errorForeground": "#ed333b",
    "icon.foreground": "#deddda",
    "sash.hoverBorder": "#00000000",
    "window.activeBorder": "#e01b24",
    "window.inactiveBorder": "#00000000",
    "textBlockQuote.background": "#00000000",
    "textBlockQuote.border": "#00000000",
    "textCodeBlock.background": "#0f0f0f",
    "textLink.activeForeground": "#f28084",
    "textLink.foreground": "#e01b24ee",
    "textPreformat.foreground": "#ffffff",
    "textPreformat.background": "#8b1a26",
    "textPreformat.border": "#00000000",
    "textSeparator.foreground": "#deddda",
    "button.background": "#8b1a26",
    "button.foreground": "#ffffff",
    "button.border": "#00000000",
    "checkbox.background": "#2e2e32",
    "checkbox.selectBackground": "#2e2e32",
    "radio.activeBackground": "#2e2e32",
    "radio.inactiveBackground": "#2e2e32",
    "dropdown.background": "#2e2e32",
    "dropdown.listBackground": "#1c1c1f",
    "input.background": "#2e2e32",
    "input.border": "#2e2e32",
    "scrollbar.background": "#00000000",
    "scrollbar.shadow": "#00000000",
    "scrollbarSlider.activeBackground": "#424246",
    "scrollbarSlider.background": "#2e2e32",
    "scrollbarSlider.hoverBackground": "#424246",
    "badge.foreground": "#241f31",
    "badge.background": "#a51d2d",
    "progressBar.background": "#e01b24",
    "list.activeSelectionBackground": "#ffffff26",
    "list.dropBackground": "#e01b2422",
    "list.focusOutline": "#00000000",
    "activityBar.background": "#222226",
    "activityBarBadge.background": "#8b1a26",
    "sideBar.background": "#222226",
    "sideBarSectionHeader.background": "#222226",
    "sideBarTitle.foreground": "#ffffff",
    "sideBarTitle.border": "#2e2e32",
    "editorGroupHeader.tabsBackground": "#1c1c1f",
    "tab.activeBackground": "#1c1c1f",
    "tab.border": "#00000000",
    "tab.inactiveBackground": "#1c1c1f",
    "editor.background": "#1c1c1f",
    "editor.selectionBackground": "#e01b2455",
    "panel.background": "#0f0f0f",
    "panelTitle.activeBorder": "#e01b24",
    "statusBar.background": "#2e2e32",
    "statusBar.debuggingBackground": "#2e2e32",
    "statusBar.noFolderBackground": "#2e2e32",
    "statusBarItem.activeBackground": "#2e2e32",
    "titleBar.activeBackground": "#2e2e32",
    "menu.foreground": "#deddda",
    "menu.background": "#2e2e32",
    "commandCenter.background": "#222226",
    "commandCenter.border": "#00000000",
    "commandCenter.activeBorder": "#00000000",
    "commandCenter.inactiveBorder": "#00000000",
    "quickInput.background": "#2e2e32"
  },
  "tokenColors": [
    {
      "name": "Comment",
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "fontStyle": "italic",
        "foreground": "#e01b24"
      }
    }
  ]
}